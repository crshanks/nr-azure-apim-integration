# Copy to .env and fill in values (never commit .env)

# Required: New Relic ingest license key (40 chars, starts with eu01xx or similar)
NEW_RELIC_LICENSE_KEY=REPLACE_ME

# Optional: Real APIM endpoint for full end-to-end demo
# Leave blank to run fully local (client → backend directly, no APIM)
APIM_ENDPOINT=https://<your-apim-instance>.azure-api.net/demo
