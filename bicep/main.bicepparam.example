// Copy this file to main.bicepparam and fill in the values.
// Do NOT commit main.bicepparam to source control (it contains secrets).
//
// Deploy with (from repo root):
//   bicep build-params bicep/main.bicepparam --outfile /tmp/main-params.json
//   bicep build bicep/main.bicep --outfile /tmp/main-arm.json
//   az deployment group create \
//     --resource-group <your-resource-group> \
//     --template-file /tmp/main-arm.json \
//     --parameters @/tmp/main-params.json

using './main.bicep'

param resourceGroupName        = '<your-resource-group>'
param location                 = 'westeurope'
param locationAbbreviation     = 'weu'
param environment              = 'dev'

param apimName                 = '<your-apim-instance-name>'
param apimResourceGroupName    = '<resource-group-containing-apim>'
param apimLoggerName           = 'apim-eventhub-logger'

// Set your New Relic ingest license key (40 chars, ends in NRAL):
param newRelicLicenseKey       = 'YOUR_40_CHAR_LICENSE_KEY_NRAL'

// Optional overrides — remove to use auto-generated names:
// param eventhubNamespaceNameOverride     = 'evhns-apim-telemetry-dev-weu'
// param logAnalyticsWorkspaceNameOverride = 'law-apim-telemetry-dev-weu'
// param containerGroupNameOverride        = 'aci-otel-collector-dev-weu'
// param storageAccountNameOverride        = 'stotelchkdevweu'   // override if org policy enforces a naming prefix (e.g. 'ststd')

// Optional production sizing overrides:
// param otelCollectorCpu      = '0.5'   // increase for higher throughput
// param otelCollectorMemoryGb = '1.0'
